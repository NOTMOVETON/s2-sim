<?xml version="1.0"?>
<robot name="dozer">
  <link name="base_footprint">
  </link>
  <link name="base_link">
    <!-- Основной корпус трактора -->
    <visual>
      <geometry>
        <box size="2.5 1.5 1.5" />
      </geometry>
      <material name="orange">
        <color rgba="1 0.3 0.1 1" />
      </material>
      <origin rpy="0 0 0" xyz="0 0 0" />
    </visual>
    <!-- Добавленная линия: от центра base_link до arm_joint -->
    <visual>
      <origin rpy="0 -0.9463 0" xyz="0.55717 -0.00004 0.773155" />
      <geometry>
        <box size="1.906 0.15 0.15" />
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="2.5 1.5 1.5" />
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0" />
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <mass value="1.5" />
      <inertia ixx="0.5625" ixy="0.0" ixz="0.0" iyy="1.0625" iyz="0.0" izz="1.0625" />
    </inertial>
  </link>
  
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin rpy="0 0 0" xyz="0 0 0" />
  </joint>

  <!-- ============================================== -->
  <!-- MIDDLE BASE LINK (ADDITIONAL FRAME)            -->
  <!-- ============================================== -->
  <link name="middle_base_link">
  </link>
  <joint name="middle_base_joint" type="fixed">
    <parent link="base_link" />
    <child link="middle_base_link" />
    <origin rpy="0 0 0" xyz="0 0 0" />
  </joint>
  <!-- ============================================== -->

  <link name="FR_wheel">
    <visual>
      <geometry>
        <cylinder length="0.25" radius="0.5" />
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.2 1 1" />
      </material>
      <origin rpy="0 0 0" xyz="0 0 0" />
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.25" radius="0.5" />
        <origin rpy="0 0 0" xyz="0 0 0" />
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <mass value="0.2" />
      <inertia ixx="0.013541666666666667" ixy="0.0" ixz="0.0" iyy="0.013541666666666667" iyz="0.0"
        izz="0.025" />
    </inertial>
  </link>
  <joint name="FR_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child link="FR_wheel" />
    <origin rpy="-1.5707963267948966 0 0" xyz="1.25 -1.0 -0.5" />
    <axis xyz="0 0 1" />
  </joint>
  
