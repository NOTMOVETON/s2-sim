  </joint>
  
  <link name="arm">
    <visual>
      <!-- Вычислено на основе координат bucket_joint -->
      <!-- Длина: ~2.8 м, центр смещен ровно наполовину, повернута на нужный угол Pitch -->
      <origin rpy="0 0.5322 0" xyz="1.206385 0.00041 -0.71071" />
      <geometry>
        <box size="2.80 0.15 0.15" />
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
  </link>
  <link name="bucket">
    <visual>
      <!-- Смещаем ковш немного вперед и вниз от сустава, чтобы видеть его вращение -->
      <origin rpy="0 0.785 0" xyz="0.3 0 -0.3" />
      <geometry>
        <box size="0.6 1.5 0.1" /> 
      </geometry>
      <material name="orange">
         <color rgba="1 0.3 0.1 1" />
      </material>
    </visual>
  </link>
  <joint name="arm_joint" type="revolute">
    <parent link="base_link" />
    <child link="arm" />
    <origin rpy="0.0 -0.5 0.0" xyz="1.11434 -0.00008 1.54631" />
    <axis xyz="0.0 1.0 0.0" />
    <limit lower="-1.0" upper="0.57" effort="200000000" velocity="0.01" />
  </joint>
  <joint name="bucket_joint" type="revolute">
    <parent link="arm" />
    <child link="bucket" />
    <origin rpy="0.0 0.0 0.0" xyz="2.41277 0.00082 -1.42142" />
    <axis xyz="0.0 1.0 0.0" />
    <limit lower="0.0" upper="0.25" effort="200000000" velocity="0.01" />
  </joint>
